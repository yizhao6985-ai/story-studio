# LLM（必填）
DEEPSEEK_API_KEY=sk-...

# 可选：OpenAI 兼容 Base URL（默认 https://api.deepseek.com）
# STORY_STUDIO_LLM_BASE_URL=https://api.deepseek.com

# 可选：聊天模型（默认 deepseek-chat）
# STORY_STUDIO_CHAT_MODEL=deepseek-chat

# 可选：Mastra API 前缀（默认 /api，需与 mastra-service server.apiPrefix 一致）
# STORY_STUDIO_MASTRA_API_PREFIX=/api
