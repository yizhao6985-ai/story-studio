    "@radix-ui/react-slot": "^1.2.4",
    "@story-studio/shared": "workspace:*",
    "@story-studio/workspace-fs": "workspace:*",
    "ai": "^7.0.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "monaco-editor": "0.55.1",
