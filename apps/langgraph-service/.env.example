# LLM（必填）
DEEPSEEK_API_KEY=sk-...

# 可选：OpenAI 兼容 Base URL（默认 https://api.deepseek.com）
# STORY_STUDIO_LLM_BASE_URL=https://api.deepseek.com

# 可选：聊天模型（默认 deepseek-chat）
# STORY_STUDIO_CHAT_MODEL=deepseek-chat

# LangSmith（langgraph dev 追踪与 Studio 调试，推荐配置）
# 在 https://smith.langchain.com/settings 创建 API Key
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=story-studio
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Story Studio MCP（独立运行 langgraph dev 时必填；Electron 内嵌模式会自动注入）
STORY_STUDIO_MCP_URL=http://127.0.0.1:3100/mcp
STORY_STUDIO_MCP_TOKEN=dev-local-token

# 本地 userData 根目录（Electron 会自动注入；CLI 调试默认 .story-studio-user-data）
# STORY_STUDIO_USER_DATA=
