{
  "name": "story-studio",
  "version": "0.1.0",
  "private": true,
  "description": "AI desktop story writing studio with local workspace, Git versioning, and multi-mode AI collaboration",
  "type": "module",
  "main": "dist-electron/main.js",
  "imports": {
    "#agent/*": "./electron/agent/*"
  },
  "scripts": {
    "dev": "vite",
    "dev:langsmith": "bash scripts/dev-langsmith.sh",
    "build": "tsc --noEmit && vite build",
    "check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "postinstall": "node scripts/rebuild-native.mjs"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.4.4",
    "@langchain/langgraph-checkpoint": "^1.1.2",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/openai": "^1.4.3",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "nanoid": "^5.1.11",
    "react": "19.2.4",
    "react-arborist": "^3.4.3",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.12.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "43.0.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^0.29.0"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
