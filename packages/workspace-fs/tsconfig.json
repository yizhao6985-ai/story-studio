{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "types": ["node"],
    "paths": {
      "@story-studio/shared": ["../shared/src/index.ts"],
      "@story-studio/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*"]
}
